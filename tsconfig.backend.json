{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "outDir": "backend-build",
    "rootDir": "backend",
    "resolveJsonModule": true
  },
  "include": ["backend/**/*.ts"],
  "exclude": ["node_modules"]
}

