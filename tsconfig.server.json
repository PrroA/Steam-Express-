{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "outDir": "server-build",
    "rootDir": ".",
    "resolveJsonModule": true
  },
  "include": ["server.ts"],
  "exclude": ["node_modules"]
}

